{
  "name": "eduthart-website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check:node": "node ./scripts/check-node.js",
    "dev": "npm run check:node && next dev",
    "dev:turbo": "npm run check:node && next dev --turbopack",
    "build": "npm run check:node && next build",
    "start": "npm run check:node && next start",
    "lint": "npm run check:node && eslint",
    "format": "npm run check:node && prettier --write .",
    "format:check": "npm run check:node && prettier --check .",
    "test:e2e": "npm run check:node && playwright test",
    "test:e2e:headed": "npm run test:e2e -- --headed",
    "test:e2e:debug": "npm run test:e2e -- --debug",
    "test:e2e:ui": "npm run test:e2e -- --ui",
    "test:e2e:report": "npm run check:node && playwright show-report"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@mux/mux-player-react": "3.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-email/render": "^1.3.1",
    "@sanity/image-url": "^1.2.0",
    "@types/leaflet": "^1.9.21",
    "@types/nodemailer": "^7.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.15.0",
    "firebase-admin": "^12.7.0",
    "gsap": "^3.13.0",
    "leaflet": "^1.9.4",
    "locomotive-scroll": "^4.1.4",
    "lucide-react": "^0.544.0",
    "motion": "^12.23.21",
    "next": "15.5.3",
    "next-sanity": "^11.1.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.65.0",
    "react-leaflet": "^5.0.0",
    "resend": "^6.1.2",
    "simple-icons": "^15.16.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "use-breakpoint": "^4.0.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5"
  }
}
